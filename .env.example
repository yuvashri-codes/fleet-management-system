# =========================================================================
# BACKEND SERVICES CONFIGURATION (Django DRF)
# =========================================================================

# Django Core Settings
DJANGO_SECRET_KEY=django-insecure-sprint1-key-enterprise-fleet-mgmt-2026
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (PostgreSQL)
DB_NAME=fleetguard_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432

# Seeding Configuration for Admin User
SEED_ADMIN_EMAIL=admin@fleetmanagement.com
SEED_ADMIN_PASSWORD=AdminPassword123!

# CORS Headers
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000


# =========================================================================
# FRONTEND SERVICE CONFIGURATION (Next.js 15)
# =========================================================================

# API connection URL
NEXT_PUBLIC_API_URL=http://localhost:8000


# =========================================================================
# ANALYTICS SERVICE CONFIGURATION (Flask)
# =========================================================================

FLASK_PORT=5001
FLASK_DEBUG=True
